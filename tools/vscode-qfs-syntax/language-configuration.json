{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    ["\"", "\""],
    ["'", "'"],
    ["(", ")"],
    ["{", "}"]
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["'", "'"],
    ["(", ")"],
    ["{", "}"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(label|if|elseif|else|while|interact|options|python)\\b.*:\\s*$",
    "decreaseIndentPattern": "^\\s*end\\b",
    "unIndentedLinePattern": "^\\s*$|^\\s*#.*$"
  }
}
